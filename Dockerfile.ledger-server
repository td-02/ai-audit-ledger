FROM rust:1.95-bookworm AS build
WORKDIR /app

COPY Cargo.toml Cargo.lock ./
COPY crates ./crates

RUN cargo build --release -p ledger-server

FROM debian:bookworm-slim
WORKDIR /app

RUN useradd -m -u 10001 ledger
COPY --from=build /app/target/release/ledger-server /usr/local/bin/ledger-server

USER ledger
EXPOSE 8080
CMD ["ledger-server"]

